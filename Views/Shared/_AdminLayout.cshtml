@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="vi">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>Admin | Nhất Long Real Estate</title>
    
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet"
          href="~/css/admin.css" />

</head>

<body>

<div class="admin-wrapper">

    <!-- Sidebar -->
    <aside class="admin-sidebar">

        <div class="sidebar-logo">

            <h2>NHẤT LONG</h2>

            <span>REAL ESTATE</span>

        </div>

        <nav class="sidebar-menu">

            <a asp-controller="AdminDashboard"
               asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="AdminDashboard" ? "active" : "")">

                <i class="bi bi-speedometer2"></i>

                <span>Dashboard</span>

            </a>

            <a asp-controller="AdminProject"
               asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="AdminProject" ? "active" : "")">

                <i class="bi bi-buildings"></i>

                <span>Dự án</span>

            </a>

            <a asp-controller="AdminCustomerLead"
               asp-action="Index"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="AdminCustomerLead" ? "active" : "")">

                <i class="bi bi-people"></i>

                <span>Khách hàng</span>

            </a>

        </nav>

        <div class="sidebar-footer">

            <div class="mb-3">

                Version 1.0

            </div>

            <a asp-controller="AdminAuth"
               asp-action="Logout"
               class="btn btn-outline-light w-100">

                <i class="bi bi-box-arrow-right"></i>

                Đăng xuất

            </a>

        </div>

    </aside>

    <!-- Content -->
    <main class="admin-content">

        <header class="admin-topbar">

            <div>

                <h5>Quản trị hệ thống</h5>

                <strong>

                    @Context.Session.GetString("AdminName")

                </strong>

            </div>

        </header>

        @RenderBody()

    </main>

</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)

</body>

</html>