@model DKRSLandingPage_WebApp.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>

<html lang="vi">

<head>

    <meta charset="utf-8"/>

    <title>Đăng nhập Admin</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>

    <link rel="stylesheet"
          href="~/css/admin.css"/>

</head>

<body class="login-page">

<div class="login-card">

    <h2>

        Admin Login

    </h2>

    <p class="text-muted mb-4">

        Nhất Long Real Estate

    </p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">

            @ViewBag.Error

        </div>
    }

    <form method="post">

        <div class="mb-3">

            <label>Tài khoản</label>

            <input asp-for="Username"
                   class="form-control"/>

        </div>

        <div class="mb-4">

            <label>Mật khẩu</label>

            <input asp-for="Password"
                   type="password"
                   class="form-control"/>

        </div>

        <button class="btn btn-primary w-100">

            Đăng nhập

        </button>

    </form>

</div>

</body>

</html>