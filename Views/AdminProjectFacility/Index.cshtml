@model List<ProjectFacility>
@{
    Layout = "_AdminLayout";
}
<div class="admin-page">

    <h2 class="mb-4">
        🏢 Quản lý tiện ích - @ViewBag.ProjectName
    </h2>

    @if (TempData["Success"] != null)
    {
        <div id="successAlert"
             class="alert alert-success">

            @TempData["Success"]

        </div>
    }

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <div class="row align-items-center">

                <div class="col-md-2">

                    <img src="@ViewBag.ProjectThumbnail"
                         class="img-fluid rounded shadow">

                </div>

                <div class="col-md-10">

                    <h4>@ViewBag.ProjectName</h4>

                    <p class="text-muted">
                        📍 @ViewBag.ProjectLocation
                    </p>

                    <span class="badge bg-primary">
                        Tổng tiện ích: @Model.Count
                    </span>

                </div>

            </div>

        </div>

    </div>

    <div class="mb-4">

        <a asp-action="Create"
           asp-route-projectId="@ViewBag.ProjectId"
           class="btn btn-success">

            + Thêm tiện ích

        </a>

        <a asp-controller="AdminProject"
           asp-action="Index"
           class="btn btn-secondary">

            ← Trở lại

        </a>

    </div>

    <table class="table table-bordered table-hover">

        <thead>

        <tr>

            <th width="80">
                STT
            </th>

            <th>
                Tên tiện ích
            </th>

            <th width="180">
                Thao tác
            </th>

        </tr>

        </thead>

        <tbody>

        @{
            var stt = 1;
        }

        @foreach (var item in Model)
        {
            <tr>

                <td>@stt</td>

                <td>@item.Name</td>

                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">

                        Sửa

                    </a>

                    <form asp-action="Delete"
                          method="post"
                          style="display:inline;">

                        <input type="hidden"
                               name="id"
                               value="@item.Id"/>

                        <button type="submit"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Bạn có chắc muốn xóa tiện ích này?')">

                            Xóa

                        </button>

                    </form>

                </td>

            </tr>

            stt++;
        }

        </tbody>

    </table>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        const alert = document.getElementById("successAlert");

        if (alert) {

            setTimeout(function () {

                alert.style.transition = "opacity .5s";

                alert.style.opacity = "0";

                setTimeout(function () {

                    alert.remove();

                }, 500);

            }, 3000);

        }

    });

</script>