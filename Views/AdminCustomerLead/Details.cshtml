@model DKRSLandingPage_WebApp.Models.CustomerLead

@{
    Layout = "_AdminLayout";
}

<div class="admin-page">

    <div class="page-header">

        <div>

            <h1 class="page-title">
                Chi tiết khách hàng
            </h1>

            <p class="page-subtitle">
                Thông tin khách hàng đã gửi yêu cầu tư vấn
            </p>

        </div>

    </div>

    <div class="admin-card">

        <div class="detail-grid">

            <div class="detail-item">

                <span>Họ và tên</span>

                <strong>@Model.FullName</strong>

            </div>

            <div class="detail-item">

                <span>Số điện thoại</span>

                <strong>@Model.Phone</strong>

            </div>

            <div class="detail-item">

                <span>Dự án quan tâm</span>

                <strong>@Model.Project?.Name</strong>

            </div>

            <div class="detail-item">

                <span>Ngày gửi</span>

                <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>

            </div>

            <div class="detail-item full-width">

                <span>Nhu cầu</span>

                <div class="message-box">

                    @Model.Message

                </div>

            </div>

        </div>

        <div class="d-flex justify-content-end mt-4">

            <a asp-action="Index"
               class="btn btn-secondary">

                Trở lại

            </a>

        </div>

    </div>

</div>