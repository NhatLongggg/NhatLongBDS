@model DKRSLandingPage_WebApp.ViewModels.ProjectImageCreateViewModel

@{
    Layout = "_AdminLayout";
}

<div class="admin-page">

    <div class="page-header">

        <div>

            <h1 class="page-title">
                Thêm ảnh dự án
            </h1>

            <p class="page-subtitle">
                Upload ảnh mới cho dự án
            </p>

        </div>

    </div>

    <div class="admin-card project-info-card">

        <img src="@ViewBag.ProjectThumbnail"
             class="project-thumbnail"
             alt="@ViewBag.ProjectName">

        <div>

            <h4 class="mb-2">
                @ViewBag.ProjectName
            </h4>

            <p class="text-muted mb-0">

                <i class="bi bi-geo-alt"></i>

                @ViewBag.ProjectLocation

            </p>

        </div>

    </div>

    <div class="admin-card">

        <form asp-action="Create"
              method="post"
              enctype="multipart/form-data"
              class="admin-form">

            <input asp-for="ProjectId" type="hidden"/>

            <div>

                <label asp-for="ImageFile"
                       class="form-label">

                    Chọn ảnh

                </label>

                <input asp-for="ImageFile"
                       class="form-control"
                       type="file"
                       accept="image/*" />

            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-success">

                    <i class="bi bi-upload"></i>

                    Upload

                </button>

                <a asp-action="Index"
                   asp-route-projectId="@Model.ProjectId"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left"></i>

                    Trở lại

                </a>

            </div>

        </form>

    </div>

</div>